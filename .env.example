# ─── Registry ────────────────────────────────────────────────────────────────
REGISTRY_MODE=catalog
REGISTRY_ALLOWED_HOSTS=codeberg.org
REGISTRY_REQUIRE_HTTPS=true
REGISTRY_CACHE_ENABLED=false
REGISTRY_CACHE_TTL_SECS=300

# Exactly one catalog source must be set:
# - REGISTRY_CATALOG_JSON (inline JSON string)
# - REGISTRY_CATALOG_FILE (path to local JSON file)
# - REGISTRY_CATALOG_URL (HTTP(S) URL to JSON catalog)
#
# Example entry:
# {"model":"re-indicators-specification","version":"0.0.3","base_url":"https://codeberg.org/CE-RISE-models/re-indicators-specification/src/tag/pages-v0.0.3/generated/"}
#REGISTRY_CATALOG_JSON={"models":[{"model":"re-indicators-specification","version":"0.0.3","base_url":"https://codeberg.org/CE-RISE-models/re-indicators-specification/src/tag/pages-v0.0.3/generated/"}]}
#REGISTRY_CATALOG_FILE=./dev/catalog.json
#REGISTRY_CATALOG_URL=https://example.org/catalog.json

# Artifact filename overrides (optional)
#REGISTRY_ARTIFACT_MAP_ROUTE=route.json
#REGISTRY_ARTIFACT_MAP_SCHEMA=schema.json
#REGISTRY_ARTIFACT_MAP_SHACL=shacl.ttl
#REGISTRY_ARTIFACT_MAP_OWL=owl.ttl
#REGISTRY_ARTIFACT_MAP_OPENAPI=openapi.json

# ─── IO Adapter ──────────────────────────────────────────────────────────────
IO_ADAPTER_ID=memory
IO_ADAPTER_VERSION=v1
#IO_ADAPTER_BASE_URL=http://io-adapter-service:9090
IO_ADAPTER_TIMEOUT_MS=5000

# ─── Auth ────────────────────────────────────────────────────────────────────
AUTH_JWKS_URL=https://keycloak.example.org/realms/ce-rise/protocol/openid-connect/certs
AUTH_ISSUER=https://keycloak.example.org/realms/ce-rise
AUTH_AUDIENCE=hex-core-service
AUTH_JWKS_REFRESH_SECS=3600

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_REQUEST_MAX_BYTES=1048576

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=info
METRICS_ENABLED=false
